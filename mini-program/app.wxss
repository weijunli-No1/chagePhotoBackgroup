/* Spatial Design System for WeChat Mini Program */
page {
  --spatial-bg: #f5f5f7;
  --spatial-card: rgba(255, 255, 255, 0.65);
  --spatial-text-main: #1d1d1f;
  --spatial-text-sub: #86868b;
  --spatial-brand: #0052D9;
  --spatial-brand-shadow: rgba(0, 82, 217, 0.25);
  
  background-color: var(--spatial-bg);
  color: var(--spatial-text-main);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
}

@media (prefers-color-scheme: dark) {
  page {
    --spatial-bg: #000000;
    --spatial-card: rgba(28, 28, 30, 0.75);
    --spatial-text-main: #f5f5f7;
    --spatial-text-sub: #98989d;
    --spatial-brand: #3b82f6;
    --spatial-brand-shadow: rgba(59, 130, 246, 0.3);

    /* TDesign Dark Mode CSS Variables */
    --td-bg-color-container: #1e1e1e;
    --td-text-color-primary: #ffffff;
    --td-text-color-secondary: #999999;
    --td-text-color-placeholder: #666666;
    --td-cell-bg-color: #1e1e1e;
    --td-cell-hover-color: #2c2c2c;
    --td-cell-border-color: #333333;
    --td-tab-bar-bg-color: #1A1A1A;
    --td-tab-bar-border-color: #333333;
  }
}


@keyframes pureFadeIn {
  from { opacity: 0; filter: blur(5px); transform: scale(0.99); }
  to { opacity: 1; filter: blur(0); transform: scale(1); }
}

.hover-scale { transition: transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1); }
.hover-scale:active { transform: scale(0.94); opacity: 0.9; }

.page-wrap {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-sizing: border-box;
}

.container {
  flex: 1;
  width: 100%;
  overflow-y: auto;
  box-sizing: border-box;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
