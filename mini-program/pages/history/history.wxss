.list-scroll {
  padding-top: 16rpx;
}
.center-wrap {
  display: flex;
  justify-content: center;
  margin-top: 160rpx;
  align-items: center;
  flex-direction: column;
}
.modern-empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  animation: slideUpFade 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.icon-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0, 82, 217, 0.08) 0%, rgba(0, 82, 217, 0.02) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  position: relative;
}

@media (prefers-color-scheme: dark) {
  .icon-circle {
    background: linear-gradient(135deg, rgba(0, 82, 217, 0.2) 0%, rgba(0, 82, 217, 0.05) 100%);
  }
}

.icon-inner {
  color: var(--td-brand-color, #0052D9);
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--td-text-color-primary, #333333);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--td-text-color-placeholder, #999999);
  text-align: center;
  margin-bottom: 64rpx;
}

.modern-btn {
  width: 360rpx;
  box-shadow: 0 12rpx 24rpx -8rpx var(--td-brand-color, rgba(0, 82, 217, 0.4));
}

.history-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 24rpx;
}
.history-card {
  width: 48%;
  background-color: var(--td-bg-color-container, #ffffff);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx -6rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  animation: slideUpFade 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  animation-fill-mode: both;
}
@keyframes slideUpFade {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 根据 nth-child 赋予级联动画延迟，实现瀑布流入场 */
.history-card:nth-child(1) { animation-delay: 0.05s; }
.history-card:nth-child(2) { animation-delay: 0.1s; }
.history-card:nth-child(3) { animation-delay: 0.15s; }
.history-card:nth-child(4) { animation-delay: 0.2s; }
.history-card:nth-child(5) { animation-delay: 0.25s; }
.history-card:nth-child(6) { animation-delay: 0.3s; }
.history-card:nth-child(n+7) { animation-delay: 0.35s; }

.history-card:active {
  transform: scale(0.95);
}
@media (prefers-color-scheme: dark) {
  .history-card {
    background-color: var(--td-bg-color-container, #222222);
    box-shadow: 0 8rpx 24rpx -6rpx rgba(0, 0, 0, 0.3);
  }
}
.img-wrap {
  width: 100%;
  height: 400rpx;
  position: relative;
  background-color: var(--td-bg-color-secondarycontainer, #f2f4f8);
}
@media (prefers-color-scheme: dark) {
  .img-wrap {
    background-color: #333;
  }
}
.thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.info-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}
.time {
  font-size: 24rpx;
  color: var(--td-text-color-primary, #333);
  font-weight: 500;
  max-width: 85%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
@media (prefers-color-scheme: dark) {
  .time { color: #ccc; }
}
.delete-btn {
  padding: 8rpx;
}
.notice-wrap {
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

@media (prefers-color-scheme: dark) {
  .notice-wrap {
    --td-notice-bar-info-bg-color: #1b2f51;
    --td-notice-bar-info-color: #4582e6;
  }
}
