
.list-scroll {
  padding: 12rpx 24rpx;
  box-sizing: border-box;
}

.center-wrap {
  display: flex;
  justify-content: center;
  margin-top: 160rpx;
  align-items: center;
  flex-direction: column;
}

.modern-empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
  animation: slideUpFade 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.icon-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(0, 82, 217, 0.08) 0%, rgba(0, 82, 217, 0.02) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
  position: relative;
}

@media (prefers-color-scheme: dark) {
  .icon-circle {
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.02) 100%);
  }
}

.icon-inner {
  color: var(--td-brand-color, #0052D9);
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--td-text-color-primary, #333333);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--td-text-color-placeholder, #999999);
  text-align: center;
  margin-bottom: 64rpx;
}

.modern-btn {
  width: 360rpx;
  box-shadow: 0 16rpx 32rpx -12rpx var(--spatial-brand-shadow, rgba(0, 82, 217, 0.4));
  font-weight: 600;
}

.history-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 24rpx;
  padding-bottom: 40rpx;
}

.history-card {
  width: calc(50% - 12rpx);
  background-color: var(--td-bg-color-container, #ffffff);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx -8rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
  animation: slideUpFade 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) both;
  animation-fill-mode: both;
}

@keyframes slideUpFade {
  from { opacity: 0; transform: translateY(30rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Skyline 不支持 :nth-child，动画延迟改为保底 0.1s */
.history-card { animation-delay: 0.1s; }

/* Skyline hover-class 替代 :active */
.card-hover {
  transform: scale(0.96) !important;
  box-shadow: 0 4rpx 16rpx -6rpx rgba(0, 0, 0, 0.04) !important;
}

.img-hover {
  opacity: 0.85;
}

.delete-hover {
  opacity: 0.6;
  transform: scale(0.9);
}

@media (prefers-color-scheme: dark) {
  .history-card {
    background-color: var(--td-bg-color-container, #222222);
    box-shadow: 0 8rpx 32rpx -8rpx rgba(0, 0, 0, 0.4);
  }
}

.img-wrap {
  width: 100%;
  /* 用明确 height 代替 aspect-ratio，Skyline 下兼容更好 */
  height: 400rpx;
  position: relative;
  background-color: var(--td-bg-color-secondarycontainer, #f2f4f8);
  overflow: hidden;
}

@media (prefers-color-scheme: dark) {
  .img-wrap {
    background-color: rgba(255, 255, 255, 0.05);
  }
}

.thumb {
  width: 100%;
  height: 100%;
  display: block;
  /* 不写 object-fit，<image> 用 mode="aspectFill" 属性控制 */
}

.info-action {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
}

.time {
  font-size: 24rpx;
  color: var(--td-text-color-secondary, #666);
  font-weight: 500;
  max-width: 80%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

@media (prefers-color-scheme: dark) {
  .time { color: #888; }
}

.delete-btn {
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.notice-wrap {
  margin-bottom: 32rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

@media (prefers-color-scheme: dark) {
  .notice-wrap {
    --td-notice-bar-info-bg-color: #1b2f51;
    --td-notice-bar-info-color: #60a5fa;
  }
}
