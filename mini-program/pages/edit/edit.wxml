<view class="page-wrap">
  <navigation-bar title="证件照制作" showBack="{{true}}" />
  <view class="main-canvas">
    <view class="image-stage">
      <image class="preview-img" mode="aspectFit" src="{{coloredBase64 ? 'data:image/jpeg;base64,' + coloredBase64 : (transparentBase64 ? 'data:image/png;base64,' + transparentBase64 : selectedImage)}}" />
    </view>

    <!-- 悬浮控制台 -->
    <view class="control-panel" wx:if="{{showColorPicker}}">
      <view class="panel-handle"></view>
      <scroll-view class="panel-scroll" scroll-y show-scrollbar="{{false}}" enhanced="{{true}}">
        <view style="padding: 10rpx 40rpx 20rpx 40rpx;">
          <!-- 尺寸选择区 -->
          <view class="panel-title">选择尺寸</view>
          <view class="size-track">
            <view class="size-node-wrap" hover-class="node-pressed" hover-stay-time="100" wx:for="{{presetSizes}}" wx:key="name" bindtap="onSizeSelect" data-index="{{index}}">
              <view class="size-node {{currentSizeIndex === index ? 'size-active' : ''}}">
                {{item.name}}
              </view>
            </view>
          </view>

          <view class="panel-title" style="margin-top: 32rpx;">选择质感背景</view>
          <view class="color-track">
            <view class="color-node-wrap" hover-class="node-pressed" hover-stay-time="100" wx:for="{{presetColors}}" wx:key="value" bindtap="onColorSelect" data-color="{{item.value}}">
              <view class="color-node {{currentBgColor === item.value && !isCustomColor ? 'node-active' : ''}}" style="background-color: {{item.value}}">
                <t-icon wx:if="{{currentBgColor === item.value && !isCustomColor}}" name="check" size="40rpx" color="{{item.value === '#FFFFFF' ? '#000' : '#FFF'}}" />
              </view>
              <view class="color-name {{currentBgColor === item.value && !isCustomColor ? 'name-active' : ''}}">{{item.name}}</view>
            </view>
            
            <!-- 自定义颜色选项 -->
            <view class="color-node-wrap" hover-class="node-pressed" hover-stay-time="100" bindtap="showColorPickerPopup">
              <view class="color-node custom-color-node {{isCustomColor ? 'node-active' : ''}}">
                <t-icon wx:if="{{isCustomColor}}" name="check" size="40rpx" color="#FFF" />
              </view>
              <view class="color-name {{isCustomColor ? 'name-active' : ''}}">自定义</view>
            </view>
          </view>
          
          <view class="action-dock" style="flex-wrap: wrap; margin-top: 32rpx;">
            <view class="btn-ghost hover-scale" hover-class="hover-scale-pressed" hover-stay-time="100" bindtap="reselect">重选图片</view>
            <view class="btn-prime hover-scale" hover-class="hover-scale-pressed" hover-stay-time="100" bindtap="savePhoto">保存单图</view>
          </view>
          <view class="action-dock" style="margin-top: 24rpx; padding-bottom: 24rpx;">
            <view class="btn-prime hover-scale" hover-class="hover-scale-pressed" hover-stay-time="100" style="background: rgba(120,120,128,0.12); color: var(--spatial-text-main);" bindtap="savePrintLayout">生成排版照并保存</view>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 颜色选择器弹窗 -->
    <t-color-picker
      visible="{{colorPickerVisible}}"
      use-popup="{{true}}"
      type="multiple"
      popup-props="{{colorPickerPopupProps}}"
      format="HEX"
      value="{{currentBgColor}}"
      bind:change="onCustomColorChange"
      bind:close="onColorPickerClose"
    />
  </view>

</view>