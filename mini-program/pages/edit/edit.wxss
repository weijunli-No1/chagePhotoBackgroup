.main-canvas {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  width: 100%;
  height: 100%;
  padding: 20rpx 0 0 0;
  box-sizing: border-box;
  position: relative;
  z-index: 10;
  overflow: hidden; /* Avoid page-level scroll */
}


.image-stage {
  flex: 1;
  min-height: 0; /* 允许 flex 子项在小屏幕下缩小而不被内容撑开 */
  margin: 0 40rpx 24rpx 40rpx;
  border-radius: 48rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 20rpx 60rpx -10rpx rgba(0,0,0,0.15);
}
.preview-img {
  width: 100%;
  height: 100%;
  display: block;
  background-color: var(--spatial-card);
}


.control-panel {
  position: relative;
  width: 100%;
  background: var(--spatial-card);
  /* backdrop-filter 在 Skyline 不支持，已移除 */
  border-radius: 0;
  padding: 32rpx 0;
  padding-bottom: max(32rpx, env(safe-area-inset-bottom));
  box-shadow: 0 -10rpx 40rpx -10rpx rgba(0,0,0,0.12);
  border-top: 2rpx solid rgba(255,255,255,0.4);
  animation: slideUp 0.7s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  box-sizing: border-box;
  flex-shrink: 0;
}

.panel-scroll {
  height: 800rpx;
  max-height: calc(70vh - 40rpx);
  width: 100%;
}
@media (prefers-color-scheme: dark) {
  .control-panel {
    border-top-color: rgba(255,255,255,0.1);
    box-shadow: 0 -10rpx 40rpx -10rpx rgba(0,0,0,0.5);
  }
}

@keyframes slideUp {
  from { transform: translateY(120rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.panel-handle {
  width: 72rpx;
  height: 10rpx;
  background: var(--spatial-text-sub);
  opacity: 0.3;
  border-radius: 10rpx;
  margin: 0 auto 32rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
}

.size-track {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.size-node-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.size-node {
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--spatial-text-main);
  background: rgba(120, 120, 128, 0.08);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.size-active {
  background: var(--spatial-brand);
  color: #FFFFFF;
  border-color: rgba(0, 82, 217, 0.3);
  box-shadow: 0 8rpx 16rpx rgba(0, 82, 217, 0.2);
}

.color-track {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: 32rpx;
  padding-bottom: 40rpx;
}

.color-node-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.custom-color-node {
  background: conic-gradient(red, yellow, lime, aqua, blue, magenta, red);
}

.color-node {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 4rpx 8rpx rgba(255,255,255,0.5), 0 8rpx 16rpx rgba(0,0,0,0.06);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 6rpx solid transparent;
}
/* :active 在 Skyline 不支持，用 hover-class="node-pressed" 替代 */
.node-pressed .color-node { transform: scale(0.9); }

.node-active {
  transform: scale(1.15) !important;
  border-color: rgba(255,255,255,0.9);
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.15);
}
.color-node[data-color="#FFFFFF"] {
  border: 2rpx solid rgba(0,0,0,0.1);
}

.color-name {
  font-size: 24rpx;
  color: var(--spatial-text-sub);
  transition: all 0.3s;
}
.name-active {
  color: var(--spatial-text-main);
  font-weight: 700;
}

.action-dock {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  gap: 32rpx;
}

.btn-ghost, .btn-prime {
  height: 104rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 32rpx;
}
.btn-ghost {
  flex: 1;
  background: rgba(120,120,128,0.12);
  color: var(--spatial-text-main);
}
.btn-prime {
  flex: 2;
  background: var(--spatial-text-main); /* 纯粹极简，极客感黑/白色按钮 */
  color: var(--spatial-bg);
  box-shadow: 0 12rpx 24rpx rgba(0,0,0,0.1);
}
@media (prefers-color-scheme: dark) {
  .btn-prime {
     background: var(--spatial-text-main);
     color: var(--spatial-bg);
  }
}
