.doc-scroll {
  flex: 1;
  background-color: var(--td-bg-color-container, #ffffff);
  padding: 40rpx;
  box-sizing: border-box;
}

.doc-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--td-font-gray-2, rgba(0, 0, 0, 0.6));
  white-space: pre-wrap;
  display: block;
}

@media (prefers-color-scheme: dark) {
  .doc-scroll {
    background-color: var(--td-bg-color-container, #1e1e1e);
  }
  .doc-text {
    color: var(--td-text-color-secondary, #999999);
  }
}
