<view class="page-wrap">
  <navigation-bar title="证件照制作" />
  <view class="main-canvas">

    <!-- Slogan + 功能亮点 -->
    <view class="hero-block">
      <view class="hero-subtitle">智能抠图 · 一键换背景 · 多种尺寸</view>
      <view class="feature-chips">
        <view class="chip">
          <t-icon name="lightning-bolt" size="28rpx" />
          <text>极速 AI</text>
        </view>
        <view class="chip">
          <t-icon name="image" size="28rpx" />
          <text>一键换底色</text>
        </view>
        <view class="chip">
          <t-icon name="print" size="28rpx" />
          <text>多规格排版</text>
        </view>
      </view>
    </view>

    <!-- 上传操作台 -->
    <!-- hover-class 替代 :active，兼容 Skyline -->
    <view class="upload-island" hover-class="island-pressed" hover-stay-time="100" bindtap="chooseImage">
      <!-- 虚线描边边框：真实 view 替代 ::after 伪元素 -->
      <view class="island-border"></view>

      <view class="upload-icon-wrap">
        <!-- 脉冲圆圈：真实 view 替代 ::before 伪元素 -->
        <view class="pulse-ring"></view>
        <view class="upload-icon">
          <t-icon name="camera" size="80rpx" />
        </view>
      </view>
      <view class="u-text">上传 / 拍摄照片</view>
      <view class="u-tip">请确保正面光线充足、面部清晰</view>

      <!-- 步骤引导 -->
      <view class="steps-row">
        <view class="step-item">
          <view class="step-num">1</view>
          <text class="step-label">选照片</text>
        </view>
        <view class="step-arrow">→</view>
        <view class="step-item">
          <view class="step-num">2</view>
          <text class="step-label">AI 处理</text>
        </view>
        <view class="step-arrow">→</view>
        <view class="step-item">
          <view class="step-num">3</view>
          <text class="step-label">保存</text>
        </view>
      </view>
    </view>

    <!-- 安全提示 -->
    <view class="privacy-tag">
      <t-icon name="cloud" size="28rpx" class="privacy-icon"/>
      <text>云端 AI 处理，极速生成不留痕</text>
    </view>
  </view>
</view>
