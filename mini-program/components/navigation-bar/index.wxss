.nav-container { 
  position: fixed; 
  top: 0; 
  left: 0; 
  width: 100%; 
  z-index: 999; 
  /* backdrop-filter 在 Skyline 不支持，已移除；通过 bgColor 传入半透明背景色实现近似效果 */
  transition: background-color 0.3s ease;
}
.nav-content { 
  display: flex; 
  align-items: center; 
  justify-content: space-between; 
  position: relative;
}
.nav-title { 
  font-size: 34rpx; /* 约等于17px */
  font-weight: 600; 
  text-align: center;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  letter-spacing: 1rpx;
  animation: titleFadeIn 0.3s ease-out;
}
@keyframes titleFadeIn {
  from { opacity: 0; transform: translate(-50%, 10rpx); }
  to { opacity: 1; transform: translate(-50%, 0); }
}
.left-box, .right-box {
  width: 160rpx; 
  height: 100%;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}
.left-box {
  padding-left: 24rpx;
}

.nav-btn-pressed {
  opacity: 0.5;
}

@media (prefers-color-scheme: dark) {
  .nav-container {
    --nav-bg-color: rgba(30, 30, 30, 0.75);
  }
}
