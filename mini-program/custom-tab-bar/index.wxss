/* 去除组件自带的背景或圆角多余边距，如果在 skyline 下有需要可以定制 */
:host {
  display: block;
}
:host {
  display: block;
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  
  /* 定义浅色模式默认变量，避免系统切回时无法回退的 Bug */
  --td-tab-bar-bg-color: #FFFFFF;
  --td-tab-bar-border-color: #E7E7E7;
  --td-bg-color-container: #FFFFFF;
  --td-text-color-primary: rgba(0, 0, 0, 0.9);
  --td-text-color-secondary: rgba(0, 0, 0, 0.6);
  --td-brand-color: #0052D9;
  --td-brand-color-light: #F2F3FF;
}

@media (prefers-color-scheme: dark) {
  :host {
    --td-tab-bar-bg-color: #1A1A1A;
    --td-tab-bar-border-color: #333333;
    --td-bg-color-container: #1A1A1A;
    --td-text-color-primary: #FFFFFF;
    --td-text-color-secondary: #999999;
    --td-brand-color: #4582E6;
    --td-brand-color-light: #1B2F51;
  }
}
